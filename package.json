{
  "name": "industrial-io",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "concurrently -n client,signal -c cyan,yellow \"pnpm --filter @industrial/client --fail-if-no-match dev\" \"pnpm --filter @industrial/signaling --fail-if-no-match dev\"",
    "build": "pnpm -r --fail-if-no-match build",
    "test": "vitest run --passWithNoTests",
    "lint": "pnpm -r --if-present lint && eslint .eslintrc.cjs --max-warnings=0",
    "format": "prettier --write .",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "eslint": "8.57.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}