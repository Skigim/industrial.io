{
  "name": "@industrial/world",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "test": "vitest run src/server.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@industrial/content": "workspace:*",
    "@industrial/sim-core": "workspace:*",
    "@industrial/transport": "workspace:*",
    "fastify": "^5.3.3"
  }
}